# REQUIRED for P2
PRIVATE_KEY=0x
TREASURY_ADDRESS=0x

# Server
PORT=8000
ENV=dev
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Avantis / Base
BASE_RPC_URL=https://mainnet.base.org
TRADING_PAIR=ETH/USD
DEFAULT_SLIPPAGE_PCT=1
MIN_LEVERAGE=75
MAX_LEVERAGE=250

# House
HOUSE_FEE_BPS=80

# Privy — multi-user delegated signing.
# When all three are set, /trade/* and /balance verify Privy access tokens
# and execute trades against the calling user's embedded wallet. When
# missing, backend falls back to legacy single-wallet mode using
# PRIVATE_KEY above (local dev only).
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# PEM-formatted public verification key from Privy dashboard:
#   App Settings -> Configuration -> Verification Key
PRIVY_VERIFICATION_KEY=
# PEM-formatted authorization private key generated locally and registered
# in Privy dashboard. Used to sign privy-authorization-signature headers
# for delegated wallet actions.
PRIVY_AUTH_PRIVATE_KEY=
PRIVY_POLICY_ID=
# Set to 1 to bypass JWT verification on /trade/* and use the legacy
# env wallet (local dev convenience).
AUTH_DISABLE=

# Supabase — trade history + leaderboard.
# When both are set, trade open/close is persisted to the `trades` table
# and /history/me + /history/leaderboard return real data. When unset,
# persistence is a no-op and those endpoints return empty lists. Apply
# `migrations/0001_init.sql` to the project before pointing prod at it.
# The SERVICE_ROLE_KEY (NOT the anon key) is required — writes bypass RLS.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Privy key-quorum alignment (the silent-401 trap).
# Set ALL THREE to the SAME quorum ID after running setup_quorum.
# Boot-time validator in main.py will refuse to silently launch with a
# mismatch — check Railway logs after redeploying for the audit banner.
PRIVY_KEY_QUORUM_ID=
PRIVY_EXPECTED_SIGNER_ID=
# Mirror NEXT_PUBLIC_PRIVY_SIGNER_ID from Vercel here too — the backend
# can't read Vercel env, so this is the only way to validate that the
# frontend's addSigners target matches the backend's quorum.
NEXT_PUBLIC_PRIVY_SIGNER_ID=
# Set to 1 once on first boot to auto-create a quorum from
# PRIVY_AUTH_PRIVATE_KEY. The script logs the new ID; copy it into the
# three vars above and remove this flag.
PRIVY_AUTO_CREATE_QUORUM=
