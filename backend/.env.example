# REQUIRED for P2
PRIVATE_KEY=0x
TREASURY_ADDRESS=0x

# Server
PORT=8000
ENV=dev
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Avantis / Base
BASE_RPC_URL=https://mainnet.base.org
TRADING_PAIR=ETH/USD
DEFAULT_SLIPPAGE_PCT=1
MIN_LEVERAGE=75
MAX_LEVERAGE=250

# House
HOUSE_FEE_BPS=80

# Privy — multi-user delegated signing.
# When all three are set, /trade/* and /balance verify Privy access tokens
# and execute trades against the calling user's embedded wallet. When
# missing, backend falls back to legacy single-wallet mode using
# PRIVATE_KEY above (local dev only).
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# PEM-formatted public verification key from Privy dashboard:
#   App Settings -> Configuration -> Verification Key
PRIVY_VERIFICATION_KEY=
# PEM-formatted authorization private key generated locally and registered
# in Privy dashboard. Used to sign privy-authorization-signature headers
# for delegated wallet actions.
PRIVY_AUTH_PRIVATE_KEY=
PRIVY_POLICY_ID=
# Set to 1 to bypass JWT verification on /trade/* and use the legacy
# env wallet (local dev convenience).
AUTH_DISABLE=

# P3 — Supabase (leave empty for now)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
